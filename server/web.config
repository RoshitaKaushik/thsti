<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <security>
      <requestFiltering>
        <!-- Increase IIS Express upload limit to ~500MB (524288000 bytes) -->
        <requestLimits maxAllowedContentLength="524288000" />
      </requestFiltering>
    </security>
    
    <httpProtocol>
      <customHeaders>
        <!-- NIC STQC Required Headers -->
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
        <!-- Basic CSP preventing external domains -->
        <add name="Content-Security-Policy" value="default-src 'self' 'unsafe-inline' 'unsafe-eval' data:; img-src 'self' data: https://placehold.co;" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
